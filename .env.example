# Basilica — Environment Variables
# Copy to .env and fill in values

# Storage
POSTGRES_URL=postgresql://basilica:basilica@localhost:5432/basilica
QDRANT_URL=http://localhost:6333

# Anthropic (Claude connector)
ANTHROPIC_API_KEY=

# GitHub (Copilot connector)
GITHUB_TOKEN=

# Dashboard
DASHBOARD_PORT=3000

# CLI
BASILICA_STORAGE_PATH=./data
