{
  "name": "basilica-vscode",
  "displayName": "Basilica",
  "description": "Track and preserve AI thread identity inside VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "basilica",
          "title": "Basilica",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "basilica": [
        {
          "id": "basilica.sessions",
          "name": "Tracked Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "basilica.startCapture",
        "title": "Basilica: Start Capturing Session"
      },
      {
        "command": "basilica.recordCheckpoint",
        "title": "Basilica: Record Formation Checkpoint"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@basilica/core": "*",
    "@basilica/openclaw": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/vscode": "^1.85.0"
  }
}
